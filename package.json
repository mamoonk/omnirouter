{
  "name": "omni-router",
  "productName": "Omni-Router",
  "version": "1.0.0",
  "description": "Multi-provider AI chat router with smart quota management",
  "author": "Omni-Router <omni-router@example.com>",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('release', {recursive:true, force:true})\"",
    "dist": "npm run clean && npm run build && electron-builder",
    "dist:win": "npm run clean && npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "build:web": "electron-vite build",
    "start:web": "tsx src/web/server.ts"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.0.0",
    "connect-sqlite3": "^0.9.16",
    "dotenv": "^16.6.1",
    "express-session": "^1.19.0",
    "highlight.js": "^11.11.1",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/generative-ai": "^0.21.0",
    "@mistralai/mistralai": "^1.0.0",
    "@tanstack/react-query": "^5.60.0",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "cohere-ai": "^7.0.0",
    "cors": "^2.8.5",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "express": "^4.21.0",
    "lucide-react": "^0.460.0",
    "openai": "^4.70.0",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "uuid": "^10.0.0"
  }
